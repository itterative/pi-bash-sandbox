{
  "$schema": "https://raw.githubusercontent.com/itterative/pi-bash-sandbox/refs/heads/main/docs/schema.json",
  "sandbox": {
    "mounts": {
      "~/.nvm": "readonly"
    }
  },
  "permissions": {
    "npm test": "allow:sandbox",
    "npm test *": "allow:sandbox",
    "npm run test:*": "allow:sandbox",
    "cd */pi-bash-sandbox/ && npm test": "allow:sandbox",
    "cd */pi-bash-sandbox/ && npm test *": "allow:sandbox",
    "cd */pi-bash-sandbox/ && npm run test:*": "allow:sandbox",
    "ls *": "allow",
    "ls * | head *": "allow",
    "sudo *": "deny",
    "pwd": "allow",
    "ls -la": "allow",
    "find . -type f -name \"*.ts\" | head *": "allow",
    "cat package.json": "allow",
    "git status": "allow",
    "wc -l *.ts": "allow",
    "echo *": "allow:sandbox",
    "git log *": "allow:sandbox",
    "git diff * | head *": "allow:sandbox",
    "npm test * | head *": "allow:sandbox",
    "npm run *": "allow:sandbox",
    "npx tsc *": "allow:sandbox",
    "cd */pi-bash-sandbox && npm run *": "allow:sandbox",
    "cd */pi-bash-sandbox && grep * *.ts": "allow:sandbox",
    "grep * *.ts": "allow:sandbox",
    "cd */pi-bash-sandbox && npx tsc --noEmit *": "allow:sandbox",
    "cd */pi-bash-sandbox && npx tsc --noEmit * | head *": "allow:sandbox",
    "grep -r * --include=*.ts | grep -v *": "allow:sandbox",
    "cd */pi-bash-sandbox && grep -r * --include=*.ts | grep -v *": "allow:sandbox"
  }
}
